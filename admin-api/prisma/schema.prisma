// prisma/schema.prisma
generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Role {
  USER
  HOST
  ADMIN
}

enum Gender {
  MALE
  FEMALE
  OTHER
}

// ⭐ stream mode for stats (solo, party, pk battles)
enum StreamMode {
  SOLO
  PARTY
  PK
}

// ⭐ PK battle type (for PK data screen)
enum PKType {
  RANDOM
 
  FRIEND
  TEAM
}

enum StreamProtocol {
  CAMERA_ONLY
  WEBRTC
  RTMP
}

// ⭐ honor wall item types
enum HonorItemType {
  TAG
  MEDAL
  GIFT
  VEHICLE
}

// ⭐ VIP tier for subscription
enum VipTier {
  NONE
  NORMAL
  SUPER
  DIAMOND
  SVIP
}

enum LiveApplicationStatus {
  PENDING
  APPROVED
  REJECTED
}

// ⭐ Moments / posts can be text, image or video
enum MomentType {
  TEXT
  IMAGE
  VIDEO
}

// ⭐ Topic category for Square topics (Daily, Official, etc.)
enum TopicCategory {
  DAILY
  OFFICIAL
  NORMAL
}

// ✅ NEW: audience targeting for admin notifications
enum NotificationAudience {
  ALL_USERS
  ALL_HOSTS
  SPECIFIC_USERS
}

model Country {
  id        Int     @id @default(autoincrement())
  code      String  @unique // e.g. "PK", "PH"
  name      String // e.g. "Pakistan"
  flagEmoji String? // e.g. "🇵🇰"
  isActive  Boolean @default(true)
  sortOrder Int     @default(0) // for custom ordering in lists

  users User[]

  @@index([sortOrder])
}

model User {
  id        String   @id @default(cuid())
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  email        String? @unique
  username     String  @unique
  passwordHash String?
  role         Role    @default(USER)
  avatarUrl    String?
  bio          String?

  // Profile fields from complete-profile screen
  nickname    String?
  dateOfBirth DateTime?
  gender      Gender?
  inviterCode String?

  countryId Int?
  country   Country? @relation(fields: [countryId], references: [id])

  // 🔐 security & bindings
  phoneNumber String? @unique
  googleId    String? @unique
  facebookId  String? @unique
  instagramId String? @unique
  tiktokId    String? @unique

  // ⚙️ per-user settings
  settings  UserSettings?
  blocks    UserBlock[]   @relation("UserBlocker")
  blockedBy UserBlock[]   @relation("UserBlocked")

  // honor items
  honors UserHonor[]

  // profile extras
  interestTags  String[] @default([])
  profilePhotos String[] @default([])

  // live streams & stream chat
  streams  Stream[]  @relation("UserStreams")
  messages Message[]
  wallet   Wallet?

  sentGifts     GiftTransaction[] @relation("GiftSender")
  receivedGifts GiftTransaction[] @relation("GiftReceiver")

  // ⭐ social graph + visits + points
  friendshipsA Friendship[] @relation("FriendA")
  friendshipsB Friendship[] @relation("FriendB")

  following Follow[] @relation("UserFollowing")
  followers Follow[] @relation("UserFollowers")

  profileVisitsMade     ProfileVisit[] @relation("Visitor")
  profileVisitsReceived ProfileVisit[] @relation("Visited")

  pointsLedger UserPointLedger[]

  // ⭐ basic progression fields
  level     Int @default(1) // wealth level
  liveLevel Int @default(1) // livestream level
  vipLevel  Int @default(0)
  exp       Int @default(0)

  // ⭐ VIP subscription status
  vipTier      VipTier   @default(NONE)
  vipExpiresAt DateTime?

  // ⭐ Live application / auth
  liveApplications LiveApplication[]
  faceVerifiedAt   DateTime?
  liveCoverUrl     String?

  // ⭐ Notifications (system / admin / message)
  notifications Notification[]

  // ✅ NEW: campaigns created by this admin
  adminNotificationsCreated AdminNotification[] @relation("AdminNotificationCreator")

  // ⭐ Direct chat (1-1 messages)
  chatThreadsA ChatThread[]  @relation("ChatThreadUserA")
  chatThreadsB ChatThread[]  @relation("ChatThreadUserB")
  chatMessages ChatMessage[]

  // moments / posts feed (Square + Video)
  moments Moment[]

  // ⬇⬇⬇ NEW back-relations for like / comment / save
  momentLikes    MomentLike[]
  momentComments MomentComment[]
  momentSaves    MomentSave[]
  // ⬆⬆⬆

  // ⭐ Fan club (each host can own one fan club)
  fanClubOwned       FanClub?
  fanClubMemberships FanClubMember[]

  // ⭐ PK battles
  pkBattlesAsHost     PKBattle[] @relation("PKHost")
  pkBattlesAsOpponent PKBattle[] @relation("PKOpponent")

  // ⭐ FEED / RANKING STATS (for Explore, Host/Rich boards, etc.)
  followersCount     Int @default(0) // number of followers
  followingCount     Int @default(0) // number of people this user follows
  totalCoinsReceived Int @default(0) // gifts received (for host / gift ranking)
  totalCoinsSpent    Int @default(0) // coins spent (for rich ranking)

  // current live status snapshot (mirrors their active Stream)
  isLive      Boolean   @default(false)
  liveViewers Int       @default(0)
  lastLiveAt  DateTime?

  // ⭐ Device management – all devices used by this user
  devices UserDevice[]

  @@index([countryId])
  @@index([createdAt])
  @@index([isLive, liveViewers])
  @@index([followersCount])
  @@index([totalCoinsReceived])
}

model Stream {
  id          String  @id @default(cuid())
  title       String
  description String?
  tag         String?

  hostId String
  host   User   @relation("UserStreams", fields: [hostId], references: [id])

  mode     StreamMode     @default(SOLO)
  protocol StreamProtocol @default(CAMERA_ONLY)

  // ✅ for LiveKit rooms
  roomName String? @unique
  roomSid  String?

  isLive       Boolean   @default(false)
  viewers      Int       @default(0)
  thumbnailUrl String?
  startedAt    DateTime?
  endedAt      DateTime?
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  messages  Message[]
  gifts     GiftTransaction[]
  pkBattles PKBattle[]

  @@index([hostId])
  @@index([isLive])
  @@index([createdAt])
  @@index([mode])
}

model Message {
  id        String   @id @default(cuid())
  createdAt DateTime @default(now())
  content   String

  streamId String
  stream   Stream @relation(fields: [streamId], references: [id])

  senderId String?
  sender   User?   @relation(fields: [senderId], references: [id])

  @@index([streamId])
  @@index([senderId])
}

model Gift {
  id        Int      @id @default(autoincrement())
  name      String
  iconUrl   String?
  price     Int // in coins
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  transactions GiftTransaction[]
}

model Wallet {
  id        String   @id @default(cuid())
  userId    String   @unique
  user      User     @relation(fields: [userId], references: [id])
  balance   Int      @default(0) // in coins
  createdAt DateTime @default(now())
  updatedAt DateTime @default(now())

  transactions GiftTransaction[]
}

model GiftTransaction {
  id        String   @id @default(cuid())
  createdAt DateTime @default(now())

  streamId String
  stream   Stream @relation(fields: [streamId], references: [id])

  giftId Int
  gift   Gift @relation(fields: [giftId], references: [id])

  senderId String
  sender   User   @relation("GiftSender", fields: [senderId], references: [id])

  receiverId String
  receiver   User   @relation("GiftReceiver", fields: [receiverId], references: [id])

  walletId String
  wallet   Wallet @relation(fields: [walletId], references: [id])

  quantity   Int @default(1)
  totalPrice Int // coins = gift.price * quantity

  @@index([streamId])
  @@index([senderId])
  @@index([receiverId])
  @@index([walletId])
  @@index([giftId])
  @@index([createdAt])
}

// ⭐ follow (for Following / Followers counts)
model Follow {
  id        String   @id @default(cuid())
  createdAt DateTime @default(now())

  followerId String
  follower   User   @relation("UserFollowing", fields: [followerId], references: [id])

  followingId String
  following   User   @relation("UserFollowers", fields: [followingId], references: [id])

  @@unique([followerId, followingId])
  @@index([followerId])
  @@index([followingId])
}

// ⭐ friendship (for Friends count)
model Friendship {
  id        String   @id @default(cuid())
  createdAt DateTime @default(now())

  userAId String
  userA   User   @relation("FriendA", fields: [userAId], references: [id])

  userBId String
  userB   User   @relation("FriendB", fields: [userBId], references: [id])

  @@unique([userAId, userBId])
  @@index([userAId])
  @@index([userBId])
}

// ⭐ profile visitors (for Visitors count)
model ProfileVisit {
  id        String   @id @default(cuid())
  createdAt DateTime @default(now())

  visitorId String
  visitor   User   @relation("Visitor", fields: [visitorId], references: [id])

  visitedId String
  visited   User   @relation("Visited", fields: [visitedId], references: [id])

  @@index([visitorId])
  @@index([visitedId])
}

// ⭐ points ledger (for Points total)
model UserPointLedger {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id])
  delta     Int
  reason    String?
  createdAt DateTime @default(now())

  @@index([userId])
}

// ⭐ per-user settings for language, notifications, privacy, privileges
model UserSettings {
  id     String @id @default(cuid())
  userId String @unique
  user   User   @relation(fields: [userId], references: [id])

  // language: "system", "en", "ur", etc.
  language String @default("system")

  // notifications
  notifyLiveAlerts   Boolean @default(true)
  notifyMessages     Boolean @default(true)
  notifySound        Boolean @default(true)
  notifyVibrate      Boolean @default(true)
  allowFromMutual    Boolean @default(true)
  allowFromFollowing Boolean @default(true)
  allowFromStrangers Boolean @default(true)

  // privileges
  invisibleVisitor Boolean @default(false)
  mysteryLive      Boolean @default(false)
  mysteryRank      Boolean @default(false)
  invisibleOnline  Boolean @default(false)
  exclusiveEmail   Boolean @default(false)
  hideLiveLevel    Boolean @default(false)

  // privacy
  hideMicStatus Boolean @default(false)
}

// ⭐ blacklist (blocked users)
model UserBlock {
  id        String   @id @default(cuid())
  createdAt DateTime @default(now())

  userId    String
  blockedId String

  user        User @relation("UserBlocker", fields: [userId], references: [id])
  blockedUser User @relation("UserBlocked", fields: [blockedId], references: [id])

  @@unique([userId, blockedId])
  @@index([userId])
  @@index([blockedId])
}

// ⭐ Honor items (for Honor Wall)
model HonorItem {
  id          String        @id @default(cuid())
  type        HonorItemType
  name        String
  description String?
  iconUrl     String?
  isActive    Boolean       @default(true)
  createdAt   DateTime      @default(now())

  userHonors UserHonor[]
}

model UserHonor {
  id         String    @id @default(cuid())
  userId     String
  user       User      @relation(fields: [userId], references: [id])
  itemId     String
  item       HonorItem @relation(fields: [itemId], references: [id])
  obtainedAt DateTime  @default(now())

  @@unique([userId, itemId])
  @@index([userId])
  @@index([itemId])
}

// ⭐ Moments / posts (Square + Video feed)
model Moment {
  id     String @id @default(cuid())
  userId String
  user   User   @relation(fields: [userId], references: [id])

  type         MomentType @default(TEXT)
  text         String?
  imageUrl     String?
  videoUrl     String?
  thumbnailUrl String?

  topicId String?
  topic   Topic?  @relation(fields: [topicId], references: [id])

  likeCount    Int @default(0)
  commentCount Int @default(0)
  shareCount   Int @default(0)
  saveCount    Int @default(0)

  createdAt DateTime @default(now())

  likes    MomentLike[]
  comments MomentComment[]
  saves    MomentSave[]

  @@index([userId, createdAt])
  @@index([topicId])
}

// ⭐ Fan Club (for Fan Club screen & live data stats)
model FanClub {
  id          String   @id @default(cuid())
  ownerId     String   @unique
  owner       User     @relation(fields: [ownerId], references: [id])
  name        String
  description String?
  createdAt   DateTime @default(now())

  members FanClubMember[]

  @@index([ownerId])
}

model FanClubMember {
  id        String   @id @default(cuid())
  fanClubId String
  fanClub   FanClub  @relation(fields: [fanClubId], references: [id])
  userId    String
  user      User     @relation(fields: [userId], references: [id])
  createdAt DateTime @default(now())

  @@unique([fanClubId, userId])
  @@index([userId])
}

// ⭐ Live applications (host verification / apply)
model LiveApplication {
  id     String                @id @default(cuid())
  userId String
  user   User                  @relation(fields: [userId], references: [id])
  status LiveApplicationStatus @default(PENDING)

  // 🧑‍💻 Base64-encoded face image captured from mobile
  faceImageBase64 String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([userId])
  @@index([status, createdAt])
}

// ⭐ PK battles (for PK data tab)
model PKBattle {
  id        String   @id @default(cuid())
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  type PKType

  hostId String
  host   User   @relation("PKHost", fields: [hostId], references: [id])

  opponentId String?
  opponent   User?   @relation("PKOpponent", fields: [opponentId], references: [id])

  streamId String?
  stream   Stream? @relation(fields: [streamId], references: [id])

  hostScore     Int @default(0)
  opponentScore Int @default(0)

  // null => draw, true => host won, false => host lost
  hostWon Boolean?

  @@index([hostId])
  @@index([opponentId])
  @@index([type])
  @@index([createdAt])
}

// ⭐ Direct chat threads (1-1)
model ChatThread {
  id        String   @id @default(cuid())
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  userAId String
  userA   User   @relation("ChatThreadUserA", fields: [userAId], references: [id])

  userBId String
  userB   User   @relation("ChatThreadUserB", fields: [userBId], references: [id])

  lastMessageText String?
  lastMessageAt   DateTime?

  messages ChatMessage[]

  @@unique([userAId, userBId], name: "userAId_userBId")
  @@index([userAId])
  @@index([userBId])
  @@index([lastMessageAt])
}

// ⭐ Direct chat messages
model ChatMessage {
  id        String   @id @default(cuid())
  createdAt DateTime @default(now())

  threadId String
  thread   ChatThread @relation(fields: [threadId], references: [id])

  senderId String
  sender   User   @relation(fields: [senderId], references: [id])

  content String
  isRead  Boolean @default(false)

  @@index([threadId])
  @@index([senderId])
  @@index([createdAt])
}

// ✅ NEW: Admin notification campaign (one-to-many into Notification)
model AdminNotification {
  id        String   @id @default(cuid())
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  createdById String
  createdBy   User   @relation("AdminNotificationCreator", fields: [createdById], references: [id])

  audience      NotificationAudience @default(ALL_USERS)
  targetUserIds String[]             @default([])
  type     String @default("ADMIN")
  title    String
  body     String
  metaJson Json?

  notifications Notification[]

  @@index([createdById, createdAt])
  @@index([audience, createdAt])
}

// ⭐ Notifications (system & admin → user, incl. chat)
model Notification {
  id     String @id @default(cuid())
  userId String
  user   User   @relation(fields: [userId], references: [id])

  // ✅ link to campaign (optional)
  adminNotificationId String?
  adminNotification   AdminNotification? @relation(fields: [adminNotificationId], references: [id])

  // e.g. SYSTEM, ADMIN, MESSAGE
  type     String @default("SYSTEM")
  title    String
  body     String
  // extra data like { liveApplicationId, status }
  metaJson Json?

  createdAt DateTime  @default(now())
  readAt    DateTime?

  @@index([userId, createdAt])
  @@index([userId, readAt])
  @@index([adminNotificationId])
}

// ⭐ Topics for Square feed (admin controlled)
model Topic {
  id          String        @id @default(cuid())
  title       String
  description String?
  isTrending  Boolean       @default(false)
  isActive    Boolean       @default(true)
  category    TopicCategory @default(NORMAL)
  sortOrder   Int           @default(0)
  hotScore    Int           @default(0)
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt

  moments Moment[]

  @@index([isTrending, sortOrder])
}

// ⭐ Likes on moments (posts / videos)
model MomentLike {
  id        String   @id @default(cuid())
  momentId  String
  moment    Moment   @relation(fields: [momentId], references: [id])
  userId    String
  user      User     @relation(fields: [userId], references: [id])
  createdAt DateTime @default(now())

  @@unique([momentId, userId])
  @@index([momentId])
  @@index([userId])
}

// ⭐ Comments on moments
model MomentComment {
  id        String   @id @default(cuid())
  momentId  String
  moment    Moment   @relation(fields: [momentId], references: [id])
  userId    String
  user      User     @relation(fields: [userId], references: [id])
  content   String
  createdAt DateTime @default(now())

  @@index([momentId])
  @@index([userId, createdAt])
}

// ⭐ Saved moments (bookmarks)
model MomentSave {
  id        String   @id @default(cuid())
  momentId  String
  moment    Moment   @relation(fields: [momentId], references: [id])
  userId    String
  user      User     @relation(fields: [userId], references: [id])
  createdAt DateTime @default(now())

  @@unique([momentId, userId])
  @@index([momentId])
  @@index([userId])
}

// ⭐ Device management – devices used to log in
model UserDevice {
  id     String @id @default(cuid())
  userId String
  user   User   @relation(fields: [userId], references: [id])

  /// Random ID stored in AsyncStorage on mobile
  deviceId     String
  deviceName   String?
  platform     String? // "android", "ios", etc.
  isTrusted    Boolean  @default(true)
  lastActiveAt DateTime @default(now())
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  @@unique([userId, deviceId])
  @@index([userId, lastActiveAt])
}
