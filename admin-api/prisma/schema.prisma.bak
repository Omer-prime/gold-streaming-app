model Stream {
  id          String   @id @default(cuid())
  title       String
  description String?
  tag         String?

  hostId String
  host   User     @relation("UserStreams", fields: [hostId], references: [id])

  mode     StreamMode     @default(SOLO)
  protocol StreamProtocol @default(CAMERA_ONLY)

  // ✅ for LiveKit rooms
  roomName String? @unique
  roomSid  String?

  isLive       Boolean   @default(false)
  viewers      Int       @default(0)
  thumbnailUrl String?
  startedAt    DateTime?
  endedAt      DateTime?
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  messages  Message[]
  gifts     GiftTransaction[]
  pkBattles PKBattle[]

  @@index([hostId])
  @@index([isLive])
  @@index([createdAt])
  @@index([mode])}
=======
