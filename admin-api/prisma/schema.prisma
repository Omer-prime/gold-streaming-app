generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Country {
  id        Int     @id @default(autoincrement())
  code      String  @unique
  name      String
  flagEmoji String?
  isActive  Boolean @default(true)
  sortOrder Int     @default(0)
  users     User[]

  @@index([sortOrder])
}

model User {
  id                 String    @id @default(cuid())
  createdAt          DateTime  @default(now())
  updatedAt          DateTime  @updatedAt
  email              String?   @unique
  username           String    @unique
  passwordHash       String?
  role               Role      @default(USER)
  avatarUrl          String?
  bio                String?
  nickname           String?
  inviterCode        String?
  countryId          Int?
  dateOfBirth        DateTime?
  gender             Gender?
  exp                Int       @default(0)
  level              Int       @default(1)
  vipLevel           Int       @default(0)
  facebookId         String?   @unique
  googleId           String?   @unique
  instagramId        String?   @unique
  phoneNumber        String?   @unique
  tiktokId           String?   @unique
  liveLevel          Int       @default(1)
  interestTags       String[]  @default([])
  profilePhotos      String[]  @default([])
  faceVerifiedAt     DateTime?
  liveCoverUrl       String?
  vipExpiresAt       DateTime?
  vipTier            VipTier   @default(NONE)
  followersCount     Int       @default(0)
  followingCount     Int       @default(0)
  isLive             Boolean   @default(false)
  lastLiveAt         DateTime?
  liveViewers        Int       @default(0)
  totalCoinsReceived Int       @default(0)
  totalCoinsSpent    Int       @default(0)

  adminNotificationsCreated AdminNotification[] @relation("AdminNotificationCreator")
  chatMessages              ChatMessage[]
  chatThreadsA              ChatThread[]        @relation("ChatThreadUserA")
  chatThreadsB              ChatThread[]        @relation("ChatThreadUserB")
  fanClubOwned              FanClub?
  fanClubMemberships        FanClubMember[]
  following                 Follow[]            @relation("UserFollowing")
  followers                 Follow[]            @relation("UserFollowers")
  friendshipsA              Friendship[]        @relation("FriendA")
  friendshipsB              Friendship[]        @relation("FriendB")
  receivedGifts             GiftTransaction[]   @relation("GiftReceiver")
  sentGifts                 GiftTransaction[]   @relation("GiftSender")
  liveApplications          LiveApplication[]
  messages                  Message[]
  moments                   Moment[]
  momentComments            MomentComment[]
  momentLikes               MomentLike[]
  momentSaves               MomentSave[]
  notifications             Notification[]
  pkBattlesAsHost           PKBattle[]          @relation("PKHost")
  pkBattlesAsOpponent       PKBattle[]          @relation("PKOpponent")
  profileVisitsReceived     ProfileVisit[]      @relation("Visited")
  profileVisitsMade         ProfileVisit[]      @relation("Visitor")
  streams                   Stream[]            @relation("UserStreams")
  country                   Country?            @relation(fields: [countryId], references: [id])
  blockedBy                 UserBlock[]         @relation("UserBlocked")
  blocks                    UserBlock[]         @relation("UserBlocker")
  devices                   UserDevice[]
  honors                    UserHonor[]
  pointsLedger              UserPointLedger[]
  settings                  UserSettings?
  wallet                    Wallet?

  // ✅ NEW (fix for Prisma opposite relations)
  currencyTrades      CurrencyTrade[]
  resellerApplication ResellerApplication?
  baseSalaryRequests  BaseSalaryRequest[]

  @@index([countryId])
  @@index([createdAt])
  @@index([isLive, liveViewers])
  @@index([followersCount])
  @@index([totalCoinsReceived])
}

model Stream {
  id           String            @id @default(cuid())
  title        String
  description  String?
  hostId       String
  isLive       Boolean           @default(false)
  viewers      Int               @default(0)
  thumbnailUrl String?
  startedAt    DateTime?
  endedAt      DateTime?
  createdAt    DateTime          @default(now())
  updatedAt    DateTime          @updatedAt
  mode         StreamMode        @default(SOLO)
  tag          String?
  protocol     StreamProtocol    @default(LIVEKIT)
  roomName     String?           @unique
  roomSid      String?
  gifts        GiftTransaction[]
  messages     Message[]
  pkBattles    PKBattle[]
  host         User              @relation("UserStreams", fields: [hostId], references: [id])

  @@index([hostId])
  @@index([isLive])
  @@index([createdAt])
  @@index([mode])
}

model Message {
  id        String   @id @default(cuid())
  createdAt DateTime @default(now())
  content   String
  streamId  String
  senderId  String?
  sender    User?    @relation(fields: [senderId], references: [id])
  stream    Stream   @relation(fields: [streamId], references: [id])

  @@index([streamId])
  @@index([senderId])
}

model Gift {
  id           Int               @id @default(autoincrement())
  name         String
  iconUrl      String?
  price        Int
  isActive     Boolean           @default(true)
  createdAt    DateTime          @default(now())
  updatedAt    DateTime          @updatedAt
  transactions GiftTransaction[]
}

model Wallet {
  id           String            @id @default(cuid())
  userId       String            @unique
  balance      Int               @default(0)
  createdAt    DateTime          @default(now())
  updatedAt    DateTime          @default(now())
  transactions GiftTransaction[]
  user         User              @relation(fields: [userId], references: [id])
}

model GiftTransaction {
  id         String   @id @default(cuid())
  createdAt  DateTime @default(now())
  streamId   String
  giftId     Int
  senderId   String
  receiverId String
  walletId   String
  quantity   Int      @default(1)
  totalPrice Int
  gift       Gift     @relation(fields: [giftId], references: [id])
  receiver   User     @relation("GiftReceiver", fields: [receiverId], references: [id])
  sender     User     @relation("GiftSender", fields: [senderId], references: [id])
  stream     Stream   @relation(fields: [streamId], references: [id])
  wallet     Wallet   @relation(fields: [walletId], references: [id])

  @@index([streamId])
  @@index([senderId])
  @@index([receiverId])
  @@index([walletId])
  @@index([giftId])
  @@index([createdAt])
}

model Follow {
  id          String   @id @default(cuid())
  createdAt   DateTime @default(now())
  followerId  String
  followingId String
  follower    User     @relation("UserFollowing", fields: [followerId], references: [id])
  following   User     @relation("UserFollowers", fields: [followingId], references: [id])

  @@unique([followerId, followingId])
  @@index([followerId])
  @@index([followingId])
}

model Friendship {
  id        String   @id @default(cuid())
  createdAt DateTime @default(now())
  userAId   String
  userBId   String
  userA     User     @relation("FriendA", fields: [userAId], references: [id])
  userB     User     @relation("FriendB", fields: [userBId], references: [id])

  @@unique([userAId, userBId])
  @@index([userAId])
  @@index([userBId])
}

model ProfileVisit {
  id        String   @id @default(cuid())
  createdAt DateTime @default(now())
  visitorId String
  visitedId String
  visited   User     @relation("Visited", fields: [visitedId], references: [id])
  visitor   User     @relation("Visitor", fields: [visitorId], references: [id])

  @@index([visitorId])
  @@index([visitedId])
}

model UserPointLedger {
  id        String   @id @default(cuid())
  userId    String
  delta     Int
  reason    String?
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id])

  @@index([userId])
}

model UserSettings {
  id                 String  @id @default(cuid())
  userId             String  @unique
  language           String  @default("system")
  notifyLiveAlerts   Boolean @default(true)
  notifyMessages     Boolean @default(true)
  notifySound        Boolean @default(true)
  notifyVibrate      Boolean @default(true)
  allowFromMutual    Boolean @default(true)
  allowFromFollowing Boolean @default(true)
  allowFromStrangers Boolean @default(true)
  invisibleVisitor   Boolean @default(false)
  mysteryLive        Boolean @default(false)
  mysteryRank        Boolean @default(false)
  invisibleOnline    Boolean @default(false)
  exclusiveEmail     Boolean @default(false)
  hideLiveLevel      Boolean @default(false)
  hideMicStatus      Boolean @default(false)
  user               User    @relation(fields: [userId], references: [id])
}

model UserBlock {
  id          String   @id @default(cuid())
  createdAt   DateTime @default(now())
  userId      String
  blockedId   String
  blockedUser User     @relation("UserBlocked", fields: [blockedId], references: [id])
  user        User     @relation("UserBlocker", fields: [userId], references: [id])

  @@unique([userId, blockedId])
  @@index([userId])
  @@index([blockedId])
}

model HonorItem {
  id          String        @id @default(cuid())
  type        HonorItemType
  name        String
  description String?
  iconUrl     String?
  isActive    Boolean       @default(true)
  createdAt   DateTime      @default(now())
  userHonors  UserHonor[]
}

model UserHonor {
  id         String    @id @default(cuid())
  userId     String
  itemId     String
  obtainedAt DateTime  @default(now())
  item       HonorItem @relation(fields: [itemId], references: [id])
  user       User      @relation(fields: [userId], references: [id])

  @@unique([userId, itemId])
  @@index([userId])
  @@index([itemId])
}

model Moment {
  id           String          @id @default(cuid())
  userId       String
  text         String?
  imageUrl     String?
  createdAt    DateTime        @default(now())
  commentCount Int             @default(0)
  likeCount    Int             @default(0)
  saveCount    Int             @default(0)
  shareCount   Int             @default(0)
  thumbnailUrl String?
  topicId      String?
  type         MomentType      @default(TEXT)
  videoUrl     String?
  topic        Topic?          @relation(fields: [topicId], references: [id])
  user         User            @relation(fields: [userId], references: [id])
  comments     MomentComment[]
  likes        MomentLike[]
  saves        MomentSave[]

  @@index([userId, createdAt])
  @@index([topicId])
}

model FanClub {
  id          String          @id @default(cuid())
  ownerId     String          @unique
  name        String
  description String?
  createdAt   DateTime        @default(now())
  owner       User            @relation(fields: [ownerId], references: [id])
  members     FanClubMember[]

  @@index([ownerId])
}

model FanClubMember {
  id        String   @id @default(cuid())
  fanClubId String
  userId    String
  createdAt DateTime @default(now())
  fanClub   FanClub  @relation(fields: [fanClubId], references: [id])
  user      User     @relation(fields: [userId], references: [id])

  @@unique([fanClubId, userId])
  @@index([userId])
}

model LiveApplication {
  id              String                @id @default(cuid())
  userId          String
  status          LiveApplicationStatus @default(PENDING)
  createdAt       DateTime              @default(now())
  updatedAt       DateTime              @updatedAt
  faceImageBase64 String?
  user            User                  @relation(fields: [userId], references: [id])

  @@index([userId])
  @@index([status, createdAt])
}

model PKBattle {
  id            String   @id @default(cuid())
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
  type          PKType
  hostId        String
  opponentId    String?
  streamId      String?
  hostScore     Int      @default(0)
  opponentScore Int      @default(0)
  hostWon       Boolean?
  host          User     @relation("PKHost", fields: [hostId], references: [id])
  opponent      User?    @relation("PKOpponent", fields: [opponentId], references: [id])
  stream        Stream?  @relation(fields: [streamId], references: [id])

  @@index([hostId])
  @@index([opponentId])
  @@index([type])
  @@index([createdAt])
}

model ChatThread {
  id              String        @id @default(cuid())
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt
  userAId         String
  userBId         String
  lastMessageText String?
  lastMessageAt   DateTime?
  messages        ChatMessage[]
  userA           User          @relation("ChatThreadUserA", fields: [userAId], references: [id])
  userB           User          @relation("ChatThreadUserB", fields: [userBId], references: [id])

  @@unique([userAId, userBId], name: "userAId_userBId")
  @@index([userAId])
  @@index([userBId])
  @@index([lastMessageAt])
}

model ChatMessage {
  id        String     @id @default(cuid())
  createdAt DateTime   @default(now())
  threadId  String
  senderId  String
  content   String
  isRead    Boolean    @default(false)
  sender    User       @relation(fields: [senderId], references: [id])
  thread    ChatThread @relation(fields: [threadId], references: [id])

  @@index([threadId])
  @@index([senderId])
  @@index([createdAt])
}

model AdminNotification {
  id            String               @id @default(cuid())
  createdAt     DateTime             @default(now())
  createdById   String
  audience      NotificationAudience @default(ALL_USERS)
  targetUserIds String[]             @default([])
  type          String               @default("ADMIN")
  title         String
  body          String
  metaJson      Json?
  createdBy     User                 @relation("AdminNotificationCreator", fields: [createdById], references: [id])
  notifications Notification[]

  @@index([createdById, createdAt])
  @@index([audience, createdAt])
}

model Notification {
  id                  String             @id @default(cuid())
  userId              String
  type                String             @default("SYSTEM")
  title               String
  body                String
  createdAt           DateTime           @default(now())
  readAt              DateTime?
  metaJson            Json?
  adminNotificationId String?
  adminNotification   AdminNotification? @relation(fields: [adminNotificationId], references: [id])
  user                User               @relation(fields: [userId], references: [id])

  @@index([userId, createdAt])
  @@index([userId, readAt])
  @@index([adminNotificationId])
}

model Topic {
  id          String        @id @default(cuid())
  title       String
  description String?
  isTrending  Boolean       @default(false)
  isActive    Boolean       @default(true)
  sortOrder   Int           @default(0)
  hotScore    Int           @default(0)
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt
  category    TopicCategory @default(NORMAL)
  moments     Moment[]

  @@index([isTrending, sortOrder])
}

model MomentLike {
  id        String   @id @default(cuid())
  momentId  String
  userId    String
  createdAt DateTime @default(now())
  moment    Moment   @relation(fields: [momentId], references: [id])
  user      User     @relation(fields: [userId], references: [id])

  @@unique([momentId, userId])
  @@index([momentId])
  @@index([userId])
}

model MomentComment {
  id        String   @id @default(cuid())
  momentId  String
  userId    String
  content   String
  createdAt DateTime @default(now())
  moment    Moment   @relation(fields: [momentId], references: [id])
  user      User     @relation(fields: [userId], references: [id])

  @@index([momentId])
  @@index([userId, createdAt])
}

model MomentSave {
  id        String   @id @default(cuid())
  momentId  String
  userId    String
  createdAt DateTime @default(now())
  moment    Moment   @relation(fields: [momentId], references: [id])
  user      User     @relation(fields: [userId], references: [id])

  @@unique([momentId, userId])
  @@index([momentId])
  @@index([userId])
}

model UserDevice {
  id           String   @id @default(cuid())
  userId       String
  /// Random ID stored in AsyncStorage on mobile
  deviceId     String
  deviceName   String?
  platform     String?
  isTrusted    Boolean  @default(true)
  lastActiveAt DateTime @default(now())
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
  user         User     @relation(fields: [userId], references: [id])

  @@unique([userId, deviceId])
  @@index([userId, lastActiveAt])
}

enum Role {
  USER
  HOST
  ADMIN
}

enum Gender {
  MALE
  FEMALE
  OTHER
}

enum StreamMode {
  SOLO
  PARTY
  PK
}

enum PKType {
  RANDOM
  FRIEND
  TEAM
}

enum StreamProtocol {
  LIVEKIT
  AGORA
}

enum HonorItemType {
  TAG
  MEDAL
  GIFT
  VEHICLE
}

enum VipTier {
  NONE
  NORMAL
  SUPER
  DIAMOND
  SVIP
}

enum LiveApplicationStatus {
  PENDING
  APPROVED
  REJECTED
}

enum MomentType {
  TEXT
  IMAGE
  VIDEO
}

enum TopicCategory {
  DAILY
  OFFICIAL
  NORMAL
}

enum NotificationAudience {
  ALL_USERS
  ALL_HOSTS
  SPECIFIC_USERS
}

// ===== NEW: Currency Trading + Salary Approval + Reseller Approval =====

model CurrencyTrade {
  id        String   @id @default(cuid())
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  userId       String
  fromCurrency String
  toCurrency   String
  fromAmount   Int
  rate         Float
  toAmount     Int
  status       CurrencyTradeStatus @default(PENDING)

  reviewedAt   DateTime?
  reviewedById String?
  note         String?

  user User @relation(fields: [userId], references: [id])

  @@index([userId, createdAt])
  @@index([status, createdAt])
}

model ResellerApplication {
  id        String   @id @default(cuid())
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  userId String                    @unique
  status ResellerApplicationStatus @default(PENDING)

  reviewedAt   DateTime?
  reviewedById String?
  note         String?

  user User @relation(fields: [userId], references: [id])

  @@index([status, createdAt])
}

model BaseSalaryRequest {
  id        String   @id @default(cuid())
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  userId   String
  amount   Int
  currency String                  @default("USD")
  status   BaseSalaryRequestStatus @default(PENDING)

  reviewedAt   DateTime?
  reviewedById String?
  note         String?

  user User @relation(fields: [userId], references: [id])

  @@index([userId, createdAt])
  @@index([status, createdAt])
}

enum CurrencyTradeStatus {
  PENDING
  APPROVED
  REJECTED
}

enum ResellerApplicationStatus {
  PENDING
  APPROVED
  REJECTED
}

enum BaseSalaryRequestStatus {
  PENDING
  APPROVED
  REJECTED
}
